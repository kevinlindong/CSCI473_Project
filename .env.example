# HuggingFace API token (needed for gated models only)
HF_TOKEN=your_token_here

# OpenRouter API key (https://openrouter.ai/keys). Required when LLM_PROVIDER=openrouter.
OPENROUTER_API_KEY=

# Provider for /api/query and /api/scoot synthesis: "local" (Qwen) or "openrouter".
LLM_PROVIDER=local

# Default OpenRouter model when LLM_PROVIDER=openrouter.
OPENROUTER_MODEL=anthropic/claude-haiku-4.5
